# TestForge 环境变量模板
# 复制为 .env 并填入实际值

# ===== 应用配置 =====
TESTFORGE_APP_NAME=TestForge
TESTFORGE_APP_VERSION=0.1.0
TESTFORGE_DEBUG=false
TESTFORGE_HOST=0.0.0.0
TESTFORGE_PORT=9876

# ===== LLM 配置 =====
TESTFORGE_LLM_PROVIDER=dashscope
TESTFORGE_LLM_MODEL=qwen-plus
TESTFORGE_LLM_API_KEY=sk-your-key
TESTFORGE_LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
TESTFORGE_LLM_FALLBACK_CHAIN=deepseek-chat,gpt-4o-mini
TESTFORGE_LLM_TEMPERATURE_CODE=0.1
TESTFORGE_LLM_TEMPERATURE_DESIGN=0.3
TESTFORGE_LLM_MAX_TOKENS_CODE=4096
TESTFORGE_LLM_MAX_TOKENS_DESIGN=8192

# ===== 本地 LLM (Ollama) =====
TESTFORGE_OLLAMA_ENABLED=true
TESTFORGE_OLLAMA_HOST=http://localhost:11434
TESTFORGE_OLLAMA_MODEL=qwen3-coder:7b

# ===== 数据库配置 =====
TESTFORGE_DATABASE_URL=sqlite+aiosqlite:///testforge.db

# ===== 安全配置 =====
#
# ===== Token 预算 =====
TESTFORGE_MONTHLY_BUDGET_USD=50.0
TESTFORGE_SECRET_KEY=请替换为随机字符串（至少32位）
TESTFORGE_SANDBOX_ENABLED=true
TESTFORGE_ADMIN_USERNAME=admin
# 管理员密码哈希（生成命令：python -c "from backend.safety.passwords import hash_password; print(hash_password('your-password'))"）
TESTFORGE_ADMIN_PASSWORD_HASH=
TESTFORGE_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
TESTFORGE_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
TESTFORGE_RATE_LIMIT_MAX_REQUESTS=200
TESTFORGE_RATE_LIMIT_WINDOW_SECONDS=60

# ===== CORS 配置 =====
TESTFORGE_CORS_ORIGINS=http://localhost:3000,http://localhost:9876,http://127.0.0.1:3000

# ===== 执行配置 =====
TESTFORGE_MAX_WORKERS=4
TESTFORGE_TIMEOUT_PER_TEST=30
TESTFORGE_TIMEOUT_TOTAL=1800
TESTFORGE_HTTP_TEST_MAX_CONCURRENCY=10
TESTFORGE_HTTP_TEST_MAX_TESTS=30
TESTFORGE_HTTP_TEST_TIMEOUT=8

# ===== 质量门禁 =====
TESTFORGE_COVERAGE_THRESHOLD=80.0
TESTFORGE_MUTATION_THRESHOLD=80.0
TESTFORGE_FLAKY_RERUN_COUNT=5

# ===== 通知配置 =====
TESTFORGE_SLACK_WEBHOOK_URL=
TESTFORGE_DINGTALK_WEBHOOK_URL=

# ===== 邮件配置 (SMTP) =====
# QQ邮箱: smtp.qq.com:465 (需开启SMTP服务获取授权码)
# Gmail: smtp.gmail.com:587 (需App Password)
# 163: smtp.163.com:465
TESTFORGE_SMTP_HOST=
TESTFORGE_SMTP_PORT=465
TESTFORGE_SMTP_USE_TLS=true
TESTFORGE_SMTP_USER=
TESTFORGE_SMTP_PASSWORD=
TESTFORGE_SMTP_TIMEOUT=30

# ===== 日志配置 =====
TESTFORGE_LOG_LEVEL=INFO
TESTFORGE_LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
TESTFORGE_LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S

# ===== RAG 配置 =====
TESTFORGE_RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
TESTFORGE_RAG_TOP_K=5
TESTFORGE_RAG_SIMILARITY_THRESHOLD=0.7

# ===== Agent 配置 =====
TESTFORGE_AGENT_MAX_ITERATIONS=8
TESTFORGE_AGENT_TIMEOUT_SECONDS=300
TESTFORGE_AGENT_TEMPERATURE=0.2

# ===== 性能配置 =====
TESTFORGE_CACHE_ENABLED=true
TESTFORGE_CACHE_TTL_SECONDS=300
TESTFORGE_DB_POOL_SIZE=5
TESTFORGE_DB_MAX_OVERFLOW=10
